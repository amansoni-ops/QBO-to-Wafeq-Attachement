# Copy this file to .env and fill in your values.

# ── QuickBooks ──
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=production
# Public URL that Intuit redirects back to (ngrok URL or your EC2 domain)
NGROK_URL=https://your-ngrok-or-domain.example.com

# ── Flask ──
FLASK_PORT=8000
FLASK_SECRET_KEY=change-me-in-production

# ── Database (optional — leave blank to use local JSON storage) ──
DATABASE_URL=

# ── Auth users (format: user1:pass1,user2:pass2 — first user becomes admin) ──
# Default if unset: admin:admin123
AUTH_USERS=admin:admin123
